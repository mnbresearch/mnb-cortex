# ---------- Supabase ----------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------- AI (set ONE; provider auto-detected) ----------
# FREE options (recommended):
#   Gemini  -> get a free key at https://aistudio.google.com/apikey  (no card, ~1500 req/day)
GEMINI_API_KEY=
#   Groq    -> get a free key at https://console.groq.com/keys
GROQ_API_KEY=
# Paid options:
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Optional: force a provider ("gemini" | "groq" | "anthropic" | "openai")
AI_PROVIDER=
